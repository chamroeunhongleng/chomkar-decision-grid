# Normalize line endings across platforms (repo is developed on Windows + CI on Linux).
# Prevents spurious CRLF/LF diffs and keeps checkouts consistent.
* text=auto eol=lf

# Explicitly treat known text types as text.
*.py    text
*.md    text
*.json  text
*.csv   text
*.yml   text
*.yaml  text
*.txt   text
*.ipynb text

# Binary assets should never be normalized.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
